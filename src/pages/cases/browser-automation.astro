            <h4>✅ 现在（自动）</h4>
            <ul>
              <li>每天耗时 2 分钟</li>
              <li>数据完整准确</li>
              <li>格式统一，可直接分析</li>
            </ul>
          </div>
        </div>
      </div>

      <h2>📚 实战案例 2：批量填写报名表</h2>
      
      <div class="example">
        <h3>场景描述</h3>
        <p>公司组织培训，需要为 20 名员工填写在线报名表，每份表单需要 5 分钟。让 AI 帮你批量完成！</p>
        
        <h3>实现代码</h3>
        <pre><code>// scripts/batch-register.cjs
const { browser } = require('openclaw');

// 员工名单
const employees = [
  { name: '张三', email: 'zhangsan@company.com', dept: '技术部' },
  { name: '李四', email: 'lisi@company.com', dept: '产品部' },
  { name: '王五', email: 'wangwu@company.com', dept: '市场部' },
  // ... 更多员工
];

async function batchRegister() {
  const formUrl = 'https://example.com/training-signup';
  
  for (const emp of employees) {
    // 打开表单
    await browser.navigate(formUrl);
    await browser.wait(1000);
    
    // 填写表单
    await browser.type('[name="name"]', emp.name);
    await browser.type('[name="email"]', emp.email);
    await browser.select('[name="department"]', emp.dept);
    
    // 提交
    await browser.click('button[type="submit"]');
    await browser.wait(2000);
    
    console.log(`✅ ${emp.name} 报名成功`);
  }
  
  console.log('🎉 所有员工报名完成！');
}

module.exports = batchRegister;</code></pre>
        
        <div class="tip warning">
          <h3>⚠️ 注意事项</h3>
          <ul>
            <li>确保目标网站允许自动化操作</li>
            <li>添加适当的延迟，避免请求过快</li>
            <li>处理可能的错误（网络问题、表单验证等）</li>
          </ul>
        </div>
      </div>

      <h2>📚 实战案例 3：自动下载日报</h2>
      
      <div class="example">
        <h3>场景描述</h3>
        <p>每天需要从 OA 系统下载日报模板，填写后再上传。让 AI 自动完成下载和上传！</p>
        
        <h3>实现代码</h3>
        <pre><code>// scripts/daily-report.cjs
const { browser } = require('openclaw');
const fs = require('fs');
const path = require('path');

async function downloadDailyReport() {
  // 登录 OA 系统
  await browser.navigate('https://oa.company.com');
  await browser.type('#username', 'your-username');
  await browser.type('#password', 'your-password');
  await browser.click('button[type="submit"]');
  await browser.wait(2000);
  
  // 进入日报页面
  await browser.navigate('https://oa.company.com/reports/daily');
  await browser.wait(1000);
  
  // 下载模板
  await browser.click('a.download-template');
  await browser.wait(5000); // 等待下载完成
  
  // 获取今天的日期
  const today = new Date().toISOString().split('T')[0];
  const downloadPath = path.join(__dirname, '..', 'downloads', `日报-${today}.xlsx`);
  
  console.log(`✅ 日报模板已下载：${downloadPath}`);
  
  // TODO: 这里可以添加自动填写逻辑
  // 使用 exceljs 等库填写日报内容
  
  return downloadPath;
}

module.exports = downloadDailyReport;</code></pre>
      </div>

      <h2>🎓 高级技巧</h2>
      
      <h3>1. 使用选择器定位元素</h3>
      <pre><code>// CSS 选择器
await browser.type('.search-input', 'keyword');
await browser.click('#submit-btn');

// XPath（复杂场景）
await browser.evaluate(() => {
  const el = document.evaluate('//button[text()="提交"]', document);
  el.click();
});

// 文本定位
await browser.click({ text: '下一步' });</code></pre>

      <h3>2. 等待元素加载</h3>
      <pre><code>// 等待固定时间
await browser.wait(2000);

// 等待元素出现
await browser.wait({ selector: '.result', timeout: 5000 });

// 等待文本消失
await browser.wait({ textGone: '加载中...', timeout: 10000 });</code></pre>

      <h3>3. 处理弹窗和对话框</h3>
      <pre><code>// 处理确认对话框
await browser.dialog({ accept: true });

// 处理文件上传
await browser.upload('input[type="file"]', 'path/to/file.pdf');</code></pre>

      <h3>4. 截图调试</h3>
      <pre><code>// 全屏截图
await browser.screenshot({ fullPage: true, path: 'debug.png' });

// 元素截图
await browser.screenshot({ 
  selector: '.error-message',
  path: 'error.png'
});</code></pre>

      <h2>⚠️ 常见问题</h2>
      
      <div class="faq">
        <div class="faq-item">
          <h4>Q: 浏览器打不开怎么办？</h4>
          <p>检查浏览器是否已安装，尝试指定浏览器路径：</p>
          <pre><code>export CHROME_PATH="/usr/bin/google-chrome"</code></pre>
        </div>
        
        <div class="faq-item">
          <h4>Q: 元素定位失败？</h4>
          <p>使用浏览器开发者工具检查元素选择器，或使用更稳定的定位方式（如 data-testid）。</p>
        </div>
        
        <div class="faq-item">
          <h4>Q: 网站有验证码怎么办？</h4>
          <p>浏览器自动化不适合处理验证码。建议：1) 寻找 API 接口 2) 手动处理验证码 3) 使用打码平台</p>
        </div>
        
        <div class="faq-item">
          <h4>Q: 如何调试自动化脚本？</h4>
          <p>1) 添加截图 2) 降低执行速度 3) 使用 browser.eval 检查页面状态 4) 分步测试</p>
        </div>
      </div>

      <div class="cta-box">
        <h3>🚀 开始你的自动化之旅</h3>
