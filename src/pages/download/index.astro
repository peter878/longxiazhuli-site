---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="下载 OpenClaw - 龙虾助理">
  <h1>📥 下载 OpenClaw</h1>
  <p class="lead">随时随地，让你的 AI 龙虾伴你左右</p>

  <div class="download-hero">
    <div class="hero-content">
      <h2>全球首款手机 OpenClaw 应用</h2>
      <p>支持 Android 和 iOS 双平台，完整功能，离线可用</p>
    </div>
  </div>

  <div class="download-options">
    <div class="download-card ios">
      <div class="platform-icon">🍎</div>
      <h3>iOS 版本</h3>
      <ul class="features">
        <li>支持 iPhone 和 iPad</li>
        <li>iOS 15.0 及以上</li>
        <li>完整功能支持</li>
        <li>离线模式</li>
      </ul>
      <div class="download-buttons">
        <a href="https://apps.apple.com/app/openclaw" class="store-btn" target="_blank">
          <span class="store-icon">🍎</span>
          <div class="store-text">
            <span class="small">Download on the</span>
            <span class="large">App Store</span>
          </div>
        </a>
      </div>
    </div>

    <div class="download-card android">
      <div class="platform-icon">🤖</div>
      <h3>Android 版本</h3>
      <ul class="features">
        <li>支持 Android 8.0 及以上</li>
        <li>各大应用商店可下载</li>
        <li>完整功能支持</li>
        <li>离线模式</li>
      </ul>
      <div class="download-buttons">
        <a href="https://play.google.com/store/apps/details?id=com.openclaw" class="store-btn" target="_blank">
          <span class="store-icon">▶️</span>
          <div class="store-text">
            <span class="small">GET IT ON</span>
            <span class="large">Google Play</span>
          </div>
        </a>
        <div class="china-stores">
          <p class="store-note">国内应用商店：</p>
          <div class="store-links">
            <a href="#" class="china-store">华为应用市场</a>
            <a href="#" class="china-store">小米应用商店</a>
            <a href="#" class="china-store">OPPO 软件商店</a>
            <a href="#" class="china-store">vivo 应用商店</a>
          </div>
        </div>
      </div>
    </div>

    <div class="download-card desktop">
      <div class="platform-icon">💻</div>
      <h3>桌面版本</h3>
      <ul class="features">
        <li>Windows / macOS / Linux</li>
        <li>完整功能支持</li>
        <li>本地部署</li>
        <li>开源免费</li>
      </ul>
      <div class="download-buttons">
        <a href="https://github.com/openclaw/openclaw" class="btn btn-github" target="_blank">
          GitHub 下载 →
        </a>
      </div>
    </div>
  </div>

  <div class="version-info">
    <h2>📱 版本信息</h2>
    <div class="version-grid">
      <div class="version-card">
        <h4>最新版本</h4>
        <p class="version-number">v1.5.0</p>
        <p class="release-date">2026 年 3 月 10 日发布</p>
      </div>
      <div class="version-card">
        <h4>应用大小</h4>
        <p class="version-number">50 MB</p>
        <p class="release-date">轻量级设计</p>
      </div>
      <div class="version-card">
        <h4>系统要求</h4>
        <p class="version-number">iOS 15+ / Android 8+</p>
        <p class="release-date">支持主流设备</p>
      </div>
    </div>
  </div>

  <div class="update-log">
    <h2>📝 更新日志</h2>
    <div class="log-item">
      <div class="log-version">v1.5.0 - 2026-03-10</div>
      <ul>
        <li>✨ 手机版正式上线</li>
        <li>🎤 新增语音输入和 TTS 语音输出</li>
        <li>💾 支持离线模式</li>
        <li>⚡ 性能优化，启动速度提升 50%</li>
        <li>🐛 修复已知问题</li>
      </ul>
    </div>
    <div class="log-item">
      <div class="log-version">v1.4.0 - 2026-02-15</div>
      <ul>
        <li>🌐 浏览器自动化功能</li>
        <li>⏰ Cron 定时任务系统</li>
        <li>📊 性能监控面板</li>
        <li>🔒 安全加固</li>
      </ul>
    </div>
  </div>

  <div class="faq-section">
    <h2>❓ 常见问题</h2>
    <div class="faq-item">
      <h4>下载后无法安装怎么办？</h4>
      <p>请检查设备系统版本是否满足要求（iOS 15+ 或 Android 8+），并确保有足够存储空间。</p>
    </div>
    <div class="faq-item">
      <h4>数据会同步吗？</h4>
      <p>手机版支持本地存储，也可通过账号同步数据。所有数据加密存储，保护隐私安全。</p>
    </div>
    <div class="faq-item">
      <h4>离线模式有哪些功能？</h4>
      <p>离线模式可访问本地记忆、技能和历史对话。需要联网的功能会标注提示。</p>
    </div>
  </div>

  <style>
    .lead {
      font-size: 1.25rem;
      color: #6b7280;
      margin-bottom: 3rem;
      text-align: center;
    }
    
    .download-hero {
      background: linear-gradient(135deg, #fef2f2 0%, #ffffff 100%);
      padding: 3rem 2rem;
      border-radius: 1rem;
      margin-bottom: 3rem;
      text-align: center;
    }
    
    .hero-content h2 {
      margin: 0 0 1rem 0;
      font-size: 2rem;
    }
    
    .hero-content p {
      font-size: 1.125rem;
      color: #6b7280;
      margin: 0;
    }
    
    .download-options {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
      margin-bottom: 4rem;
    }
    
    .download-card {
      border: 1px solid #e5e7eb;
      border-radius: 1rem;
      padding: 2rem;
      text-align: center;
      transition: all 0.3s;
    }
    
    .download-card:hover {
      box-shadow: 0 8px 16px rgba(0,0,0,0.1);
      transform: translateY(-4px);
    }
    
    .platform-icon {
      font-size: 4rem;
      margin-bottom: 1rem;
    }
    
    .download-card h3 {
      margin: 0 0 1.5rem 0;
    }
    
    .features {
      list-style: none;
      padding: 0;
      margin: 0 0 2rem 0;
      text-align: left;
    }
    
    .features li {
      padding: 0.5rem 0;
      border-bottom: 1px solid #f3f4f6;
      color: #6b7280;
    }
    
    .features li:last-child {
      border-bottom: none;
    }
    
    .download-buttons {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      align-items: center;
    }
    
    .store-btn {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      background: #000;
      color: white;
      padding: 0.75rem 1.5rem;
      border-radius: 0.5rem;
      text-decoration: none;
      transition: all 0.2s;
      width: 100%;
      max-width: 250px;
      justify-content: center;
    }
    
    .store-btn:hover {
      background: #333;
      transform: scale(1.05);
    }
    
    .store-icon {
      font-size: 1.5rem;
    }
    
    .store-text {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
    }
    
    .store-text .small {
      font-size: 0.625rem;
      text-transform: uppercase;
    }
    
    .store-text .large {
      font-size: 1.125rem;
      font-weight: 600;
    }
    
    .china-stores {
      width: 100%;
      max-width: 250px;
      margin-top: 1rem;
      padding-top: 1rem;
      border-top: 1px solid #e5e7eb;
    }
    
    .store-note {
      font-size: 0.875rem;
      color: #6b7280;
      margin-bottom: 0.75rem;
    }
    
    .store-links {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    
    .china-store {
      flex: 1 1 calc(50% - 0.25rem);
      padding: 0.5rem;
      background: #f9fafb;
      border: 1px solid #e5e7eb;
      border-radius: 0.375rem;
      text-decoration: none;
      color: #374151;
      font-size: 0.75rem;
      text-align: center;
      transition: all 0.2s;
    }
    
    .china-store:hover {
      background: #fef2f2;
      border-color: #dc2626;
      color: #dc2626;
    }
    
    .btn-github {
      background: #24292e;
      color: white;
      padding: 0.75rem 1.5rem;
      border-radius: 0.5rem;
      text-decoration: none;
      transition: background 0.2s;
    }
    
    .btn-github:hover {
      background: #1a1e23;
    }
    
    .version-info {
      margin-bottom: 3rem;
    }
    
    .version-info h2,
    .update-log h2,
    .faq-section h2 {
      text-align: center;
      margin-bottom: 2rem;
    }
    
    .version-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.5rem;
      margin-bottom: 3rem;
    }
    
    .version-card {
      background: #f9fafb;
      padding: 1.5rem;
      border-radius: 0.75rem;
      text-align: center;
    }
    
    .version-card h4 {
      margin: 0 0 0.5rem 0;
      color: #6b7280;
      font-size: 0.875rem;
    }
    
    .version-number {
      font-size: 1.5rem;
      font-weight: 700;
      color: #dc2626;
      margin: 0.5rem 0;
    }
    
    .release-date {
      color: #6b7280;
      font-size: 0.875rem;
      margin: 0;
    }
    
    .update-log {
      margin-bottom: 3rem;
    }
    
    .log-item {
      background: #f9fafb;
      padding: 1.5rem;
      border-radius: 0.75rem;
      margin-bottom: 1rem;
    }
    
    .log-version {
      font-weight: 600;
      color: #dc2626;
      margin-bottom: 1rem;
    }
    
    .log-item ul {
      margin: 0;
      padding-left: 1.5rem;
      color: #6b7280;
    }
    
    .log-item li {
      margin: 0.5rem 0;
    }
    
    .faq-section {
      margin-bottom: 3rem;
    }
    
    .faq-item {
      background: white;
      border: 1px solid #e5e7eb;
      border-radius: 0.75rem;
      padding: 1.5rem;
      margin-bottom: 1rem;
    }
    
    .faq-item h4 {
      margin: 0 0 0.75rem 0;
      color: #1f2937;
    }
    
    .faq-item p {
      margin: 0;
      color: #6b7280;
    }
  </style>
</BaseLayout>
